# Test Environment - Local Development
# Copy to .env.test

# Server Configuration
PORT=4000
NODE_ENV=test

# Database (local test database)
DATABASE_URL=postgresql://user:password@localhost:5432/swiip_test

# AI Configuration (test keys or leave empty)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AI_MODEL=gpt-4o-mini
AI_DAILY_FREE_LIMIT=10

# Like Limits
LIKE_DAILY_FREE_LIMIT=15
LIKE_REWARD_AMOUNT=3
LIKE_MAX_REWARDS_PER_DAY=5

# Admin (test key)
ADMIN_KEY=test_admin_key_123

# RevenueCat Webhook (not needed for test)
REVENUECAT_WEBHOOK_SECRET=
APP_BASE_URL=http://localhost:4000

