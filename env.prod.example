# Production Environment
# Copy to .env.prod

# Server Configuration
PORT=4000
NODE_ENV=production

# Database (production database)
DATABASE_URL=postgresql://user:password@prod-db-host:5432/swiip_prod

# AI Configuration (production keys)
AI_PROVIDER=openai
OPENAI_API_KEY=your_prod_openai_key
OPENROUTER_API_KEY=your_prod_openrouter_key
AI_MODEL=gpt-4o-mini
AI_DAILY_FREE_LIMIT=10
MSG_DAILY_FREE_LIMIT=30

# Like Limits
LIKE_DAILY_FREE_LIMIT=15
LIKE_REWARD_AMOUNT=3
LIKE_MAX_REWARDS_PER_DAY=5

# Admin (strong production key)
ADMIN_KEY=your_strong_prod_admin_key

# RevenueCat Webhook (production webhook secret - REQUIRED)
REVENUECAT_WEBHOOK_SECRET=your_prod_webhook_secret
APP_BASE_URL=https://api.swiip.app

