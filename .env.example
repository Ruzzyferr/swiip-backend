# Server Configuration
PORT=4000
NODE_ENV=development

# Database
# PostgreSQL connection string
# Format: postgresql://user:password@localhost:5432/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swiip

# AI Configuration
# Provider: "openai" or "openrouter"
AI_PROVIDER=openai

# OpenAI Configuration (required if AI_PROVIDER=openai)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenRouter Configuration (required if AI_PROVIDER=openrouter)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# AI Model
# Default: gpt-4o-mini (cheap and fast)
# Other options: gpt-4o, gpt-3.5-turbo, claude-3-haiku, etc.
AI_MODEL=gpt-4o-mini

# Usage Limits (for free users)
# Daily AI polish limit per user
AI_DAILY_FREE_LIMIT=10

# Admin
ADMIN_KEY=your_admin_key_here

# RevenueCat Webhook
# Get this from RevenueCat Dashboard -> Integrations -> Webhooks -> Authorization header value
REVENUECAT_WEBHOOK_SECRET=your_webhook_secret_here

# App Base URL (optional, for documentation)
APP_BASE_URL=https://your-domain.com