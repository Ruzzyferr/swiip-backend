# Dev Environment - Development/Staging
# Copy to .env.dev

# Server Configuration
PORT=4000
NODE_ENV=development

# Database (dev database)
DATABASE_URL=postgresql://user:password@dev-db-host:5432/conversa_dev

# AI Configuration (dev/test keys)
AI_PROVIDER=openai
OPENAI_API_KEY=your_dev_openai_key
OPENROUTER_API_KEY=your_dev_openrouter_key
AI_MODEL=gpt-4o-mini
AI_DAILY_FREE_LIMIT=10

# Like Limits
LIKE_DAILY_FREE_LIMIT=15
LIKE_REWARD_AMOUNT=3
LIKE_MAX_REWARDS_PER_DAY=5

# Admin
ADMIN_KEY=your_dev_admin_key

# RevenueCat Webhook (dev webhook secret)
REVENUECAT_WEBHOOK_SECRET=your_dev_webhook_secret
APP_BASE_URL=https://api-dev.conversa.app

