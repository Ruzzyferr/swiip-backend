# ==============================================
# Production Environment Variables for Docker
# ==============================================
# Copy this file to .env.docker and fill in the values
# Usage: docker-compose -f docker-compose.prod.yml --env-file .env.docker up -d

# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_strong_database_password
DB_NAME=swiip

# MinIO Configuration
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your_strong_minio_password

# S3 Public URL (your domain or server IP)
# This is the URL that mobile app will use to access images
S3_PUBLIC_URL=https://your-domain.com:9000/swiip-photos

# AI Configuration
AI_PROVIDER=openrouter
OPENAI_API_KEY=sk-your-openai-api-key
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
AI_MODEL=gpt-4o-mini

# Usage Limits
AI_DAILY_FREE_LIMIT=5
LIKE_DAILY_FREE_LIMIT=10
LIKE_REWARD_AMOUNT=3
LIKE_MAX_REWARDS_PER_DAY=5
DIRECT_WEEKLY_FREE_LIMIT=1
DIRECT_WEEKLY_PREMIUM_LIMIT=5

# Admin
ADMIN_KEY=your_strong_admin_key

# RevenueCat (required for production)
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret

# App Base URL
APP_BASE_URL=https://api.your-domain.com

# Google OAuth (optional)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id_here
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id_here
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id_here
