# Server Configuration
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/conversa
DIRECT_URL=postgresql://user:password@localhost:5432/conversa

# AI Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=gpt-4o-mini
AI_DAILY_FREE_LIMIT=10

# Like Limits
LIKE_DAILY_FREE_LIMIT=15
LIKE_REWARD_AMOUNT=3
LIKE_MAX_REWARDS_PER_DAY=5

# Direct Message Limits (Weekly)
DIRECT_WEEKLY_FREE_LIMIT=1
DIRECT_WEEKLY_PREMIUM_LIMIT=5

# Admin
ADMIN_KEY=your_admin_key_here

# RevenueCat Webhook
# Get this from RevenueCat Dashboard -> Integrations -> Webhooks -> Authorization header value
REVENUECAT_WEBHOOK_SECRET=your_webhook_secret_here

# App Base URL (optional, for documentation)
APP_BASE_URL=https://your-domain.com

